<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/ai_assistant_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/stellog_background"
    tools:context=".ui.AiAssistantActivity">

    <TextView
        android:id="@+id/ai_assistant_close_button"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="26dp"
        android:background="@drawable/bg_icon_button"
        android:gravity="center"
        android:text="x"
        android:textColor="@color/stellog_muted"
        android:textSize="28sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/ai_assistant_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="34dp"
        android:includeFontPadding="false"
        android:text="AI 助手"
        android:textColor="@color/stellog_ink"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:id="@+id/ai_assistant_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="22dp"
        android:paddingTop="24dp"
        android:paddingEnd="22dp"
        android:paddingBottom="18dp"
        app:layout_constraintBottom_toTopOf="@id/ai_quick_actions"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ai_assistant_title">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/ai_chat_messages"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:orientation="vertical">
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <HorizontalScrollView
        android:id="@+id/ai_quick_actions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingStart="22dp"
        android:paddingTop="6dp"
        android:paddingEnd="22dp"
        android:paddingBottom="10dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/ai_input_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/ai_chip_review"
                style="@style/AiChip"
                android:text="本周复盘" />

            <TextView
                android:id="@+id/ai_chip_risk"
                style="@style/AiChip"
                android:text="中断风险" />

            <TextView
                android:id="@+id/ai_chip_time"
                style="@style/AiChip"
                android:text="打卡时间" />

            <TextView
                android:id="@+id/ai_chip_encourage"
                style="@style/AiChip"
                android:text="鼓励一下" />
        </LinearLayout>
    </HorizontalScrollView>

    <LinearLayout
        android:id="@+id/ai_input_bar"
        android:layout_width="0dp"
        android:layout_height="78dp"
        android:background="@color/stellog_surface"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <EditText
            android:id="@+id/ai_message_input"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:background="@drawable/bg_ai_input"
            android:hint="输入你想咨询的问题"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:singleLine="true"
            android:textColor="@color/stellog_ink"
            android:textColorHint="@color/stellog_muted"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/ai_send_button"
            android:layout_width="68dp"
            android:layout_height="46dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_create_action_primary"
            android:gravity="center"
            android:text="发送"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
