<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"

    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="提醒设置"
        android:textColor="@color/stellog_ink"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/stellog_muted"
        android:textSize="14sp"
        android:text="设置每天提醒你打卡的时间" />

    <TextView
        android:id="@+id/reminder_habit_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:textColor="@color/stellog_primary"
        android:textSize="28sp"
        android:textStyle="bold"
        android:text="活动名称" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_calendar_panel"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="开启提醒"
            android:textColor="@color/stellog_ink"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Switch
            android:id="@+id/reminder_enable_switch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/reminder_time_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_calendar_panel"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="提醒时间"
            android:textColor="@color/stellog_ink"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/reminder_time_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="08:00"
            android:textColor="@color/stellog_primary"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:gravity="end"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/reminder_cancel_button"
            android:layout_width="120dp"
            android:layout_height="46dp"
            android:gravity="center"
            android:text="取消"
            android:textColor="@color/stellog_muted"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/reminder_save_button"
            android:layout_width="120dp"
            android:layout_height="46dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_check_in_button"
            android:gravity="center"
            android:text="保存"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
