<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="16dp"
    android:paddingEnd="16dp">

    <LinearLayout
        android:id="@+id/habit_card_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_main_habit_card_undone"
        android:elevation="3dp"
        android:orientation="vertical">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/card_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingTop="18dp"
                android:paddingEnd="28dp"
                android:paddingBottom="20dp">

                <ImageView
                    android:id="@+id/card_reminder_button"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_gravity="center_horizontal"
                    android:alpha="0.5"
                    android:contentDescription="提醒"
                    android:padding="6dp"
                    android:src="@drawable/ic_bell" />

                <TextView
                    android:id="@+id/habit_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:includeFontPadding="false"
                    android:text="看书"
                    android:textColor="@color/stellog_ink"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/streak_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:includeFontPadding="false"
                    android:text="0"
                    android:textColor="@color/stellog_primary"
                    android:textSize="52sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="天收获"
                    android:textColor="@color/stellog_ink"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/target_summary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="今日 0 · 累计 0"
                    android:textColor="@color/stellog_muted"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/priority_hint_chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_chip"
                    android:paddingStart="14dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="6dp"
                    android:text="保持当前节奏"
                    android:textColor="@color/stellog_primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/week_labels"
                    android:layout_width="match_parent"
                    android:layout_height="26dp"
                    android:layout_marginTop="14dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        style="@style/WeekLabel"
                        android:text="一"
                        android:textColor="@color/stellog_primary" />

                    <TextView
                        style="@style/WeekLabel"
                        android:text="二" />

                    <TextView
                        style="@style/WeekLabel"
                        android:text="三" />

                    <TextView
                        style="@style/WeekLabel"
                        android:text="四" />

                    <TextView
                        style="@style/WeekLabel"
                        android:text="五" />

                    <TextView
                        style="@style/WeekLabel"
                        android:text="六" />

                    <TextView
                        style="@style/WeekLabel"
                        android:text="日" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/week_checks"
                    android:layout_width="match_parent"
                    android:layout_height="34dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <FrameLayout style="@style/WeekDotColumn">
                        <TextView
                            android:id="@+id/week_dot_monday"
                            style="@style/WeekDot"
                            android:layout_gravity="center" />
                    </FrameLayout>

                    <FrameLayout style="@style/WeekDotColumn">
                        <TextView
                            android:id="@+id/week_dot_tuesday"
                            style="@style/WeekDot"
                            android:layout_gravity="center" />
                    </FrameLayout>

                    <FrameLayout style="@style/WeekDotColumn">
                        <TextView
                            android:id="@+id/week_dot_wednesday"
                            style="@style/WeekDot"
                            android:layout_gravity="center" />
                    </FrameLayout>

                    <FrameLayout style="@style/WeekDotColumn">
                        <TextView
                            android:id="@+id/week_dot_thursday"
                            style="@style/WeekDot"
                            android:layout_gravity="center" />
                    </FrameLayout>

                    <FrameLayout style="@style/WeekDotColumn">
                        <TextView
                            android:id="@+id/week_dot_friday"
                            style="@style/WeekDot"
                            android:layout_gravity="center" />
                    </FrameLayout>

                    <FrameLayout style="@style/WeekDotColumn">
                        <TextView
                            android:id="@+id/week_dot_saturday"
                            style="@style/WeekDot"
                            android:layout_gravity="center" />
                    </FrameLayout>

                    <FrameLayout style="@style/WeekDotColumn">
                        <TextView
                            android:id="@+id/week_dot_sunday"
                            style="@style/WeekDot"
                            android:layout_gravity="center" />
                    </FrameLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="8dp"
                    android:background="@color/stellog_line" />

                <TextView
                    android:id="@+id/today_date"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="今天 | 2026-05-11"
                    android:textColor="@color/stellog_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/check_in_button"
                    android:layout_width="150dp"
                    android:layout_height="46dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_check_in_button"
                    android:elevation="2dp"
                    android:gravity="center"
                    android:text="打卡"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/checked_actions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="116dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="已收获"
                            android:textColor="@color/stellog_muted"
                            android:textSize="18sp" />

                        <TextView
                            android:id="@+id/record_detail_button"
                            android:layout_width="116dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="记录详细"
                            android:textColor="@color/stellog_muted"
                            android:textSize="18sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/cancel_check_in_button"
                        android:layout_width="match_parent"
                        android:layout_height="34dp"
                        android:gravity="center"
                        android:text="取消"
                        android:textColor="@color/stellog_muted"
                        android:textSize="18sp" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</FrameLayout>
