<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/ai_settings_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/stellog_background">

    <TextView
        android:id="@+id/ai_settings_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="34dp"
        android:layout_marginStart="28dp"
        android:text="AI 设置"
        android:textColor="@color/stellog_ink"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/ai_settings_close"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="28dp"
        android:gravity="center"
        android:text="×"
        android:textColor="@color/stellog_ink"
        android:textSize="28sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/ai_settings_title" />

    <EditText
        android:id="@+id/api_key_input"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="36dp"
        android:background="@drawable/bg_ai_input"
        android:hint="请输入 API Key（支持deepseek系列）"
        android:inputType="textPassword"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:singleLine="true"
        android:textColor="@color/stellog_ink"
        android:textSize="15sp"
        app:layout_constraintEnd_toEndOf="@id/ai_settings_close"
        app:layout_constraintStart_toStartOf="@id/ai_settings_title"
        app:layout_constraintTop_toBottomOf="@id/ai_settings_title" />

    <TextView
        android:id="@+id/save_api_key_button"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_create_action_primary"
        android:gravity="center"
        android:text="保存"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="@id/api_key_input"
        app:layout_constraintStart_toStartOf="@id/api_key_input"
        app:layout_constraintTop_toBottomOf="@id/api_key_input" />

</androidx.constraintlayout.widget.ConstraintLayout>