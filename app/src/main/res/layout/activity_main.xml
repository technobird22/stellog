<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF1EF"
    android:clipChildren="false"
    android:clipToPadding="false"
    tools:context=".ui.MainActivity">

    <LinearLayout
        android:id="@+id/view_mode_switch"
        android:layout_width="148dp"
        android:layout_height="40dp"
        android:layout_marginTop="28dp"
        android:background="@drawable/bg_mode_switch"
        android:elevation="2dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/card_mode"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:background="@drawable/bg_mode_selected"
            android:gravity="center"
            android:text="卡片"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/list_mode"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="列表"
            android:textColor="@color/stellog_muted"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/habit_pager"
        android:layout_width="0dp"
        android:layout_height="500dp"
        android:layout_marginTop="40dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/view_mode_switch" />

    <LinearLayout
        android:id="@+id/page_dots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/habit_pager" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/habit_list"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="22dp"
        android:paddingTop="28dp"
        android:paddingEnd="22dp"
        android:paddingBottom="110dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottom_tabs"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/view_mode_switch"
        tools:listitem="@layout/item_habit_list" />

    <TextView
        android:id="@+id/empty_home_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="还没有活动，点击右下角 + 创建第一个吧"
        android:textColor="@color/stellog_muted"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottom_tabs"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/view_mode_switch" />

    <ScrollView
        android:id="@+id/calendar_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="22dp"
        android:paddingTop="28dp"
        android:paddingEnd="22dp"
        android:paddingBottom="24dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottom_tabs"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="invisible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="42dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:text="日历"
                    android:textColor="@color/stellog_ink"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/calendar_activity_filter_button"
                    android:layout_width="172dp"
                    android:layout_height="42dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_calendar_activity_filter"
                    android:elevation="2dp"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingEnd="14dp">

                    <TextView
                        android:id="@+id/calendar_activity_filter_label"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="全部活动"
                        android:textColor="@color/stellog_ink"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="22dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="⌄"
                        android:textColor="@color/stellog_muted"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </FrameLayout>
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:background="@drawable/bg_calendar_panel"
                android:elevation="3dp"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/calendar_prev_month"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:gravity="center"
                        android:text="‹"
                        android:textColor="@color/stellog_muted"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/calendar_month_title"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:textColor="@color/stellog_ink"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        tools:text="2026 年 5 月" />

                    <TextView
                        android:id="@+id/calendar_next_month"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:gravity="center"
                        android:text="›"
                        android:textColor="@color/stellog_muted"
                        android:textSize="28sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="28dp"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <TextView
                        style="@style/CalendarWeekLabel"
                        android:text="一" />

                    <TextView
                        style="@style/CalendarWeekLabel"
                        android:text="二" />

                    <TextView
                        style="@style/CalendarWeekLabel"
                        android:text="三" />

                    <TextView
                        style="@style/CalendarWeekLabel"
                        android:text="四" />

                    <TextView
                        style="@style/CalendarWeekLabel"
                        android:text="五" />

                    <TextView
                        style="@style/CalendarWeekLabel"
                        android:text="六" />

                    <TextView
                        style="@style/CalendarWeekLabel"
                        android:text="日" />
                </LinearLayout>

                <android.widget.GridLayout
                    android:id="@+id/calendar_grid"
                    android:layout_width="match_parent"
                    android:layout_height="264dp"
                    android:alignmentMode="alignBounds"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:columnCount="7"
                    android:rowCount="6"
                    android:useDefaultMargins="false" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_calendar_panel"
                android:elevation="3dp"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/calendar_selected_date_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5 月 12 日"
                        android:textColor="@color/stellog_ink"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/calendar_selected_date_hint"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:gravity="end"
                        android:singleLine="true"
                        android:textColor="@color/stellog_muted"
                        android:textSize="14sp"
                        android:textStyle="italic" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/calendar_selected_records"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="vertical" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/calendar_completed_count"
                        style="@style/CalendarStatValue"
                        android:text="1" />

                    <TextView
                        android:id="@+id/calendar_plan_count"
                        style="@style/CalendarStatValue"
                        android:text="2" />

                    <TextView
                        android:id="@+id/calendar_completion_rate"
                        style="@style/CalendarStatValue"
                        android:text="50%" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:orientation="horizontal">

                    <TextView
                        style="@style/CalendarStatLabel"
                        android:text="已完成" />

                    <TextView
                        style="@style/CalendarStatLabel"
                        android:text="计划数" />

                    <TextView
                        style="@style/CalendarStatLabel"
                        android:text="完成率" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <ScrollView
        android:id="@+id/achievement_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="22dp"
        android:paddingTop="28dp"
        android:paddingEnd="22dp"
        android:paddingBottom="110dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottom_tabs"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <ScrollView
        android:id="@+id/profile_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="22dp"
        android:paddingTop="28dp"
        android:paddingEnd="22dp"
        android:paddingBottom="110dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottom_tabs"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:gravity="center_vertical"
                android:text="我的"
                android:textColor="@color/stellog_ink"
                android:textSize="30sp"
                android:textStyle="bold" />


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_calendar_panel"
                android:elevation="3dp"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="账户数据"
                    android:textColor="@color/stellog_ink"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center_vertical"
                    android:text="创建活动    3"
                    android:textColor="@color/stellog_ink"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center_vertical"
                    android:text="累计记录    28"
                    android:textColor="@color/stellog_ink"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center_vertical"
                    android:text="最长连续    12 天"
                    android:textColor="@color/stellog_ink"
                    android:textSize="16sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ai_assistant_entry"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_calendar_panel"
                android:elevation="3dp"
                android:orientation="vertical"
                android:padding="20dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI 助手"
                    android:textColor="@color/stellog_ink"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="围绕习惯养成与打卡复盘提问"
                    android:textColor="#6E756F"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ai_settings_entry"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_calendar_panel"
                android:elevation="3dp"
                android:orientation="vertical"
                android:padding="20dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI设置"
                    android:textColor="@color/stellog_ink"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="设置 API Key"
                    android:textColor="#6E756F"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/smart_recommendation_entry"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_calendar_panel"
                android:elevation="3dp"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="智能推荐排序"
                        android:textColor="@color/stellog_ink"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/smart_recommendation_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="关闭后按创建顺序展示"
                    android:textColor="#6E756F"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottom_tabs"
        android:layout_width="0dp"
        android:layout_height="86dp"
        android:background="@drawable/bg_bottom_nav"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/home_tab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="首页"
            android:textColor="@color/stellog_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/calendar_tab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="日历"
            android:textColor="#575D5A"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/achievement_tab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="成就"
            android:textColor="#575D5A"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/profile_tab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="我的"
            android:textColor="#575D5A"
            android:textSize="18sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/add_activity_button"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginEnd="22dp"
        android:layout_marginBottom="18dp"
        android:background="@drawable/bg_add_fab"
        android:elevation="12dp"
        android:gravity="center"
        android:text="+"
        android:textColor="@color/white"
        android:textSize="36sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/bottom_tabs"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/main_loading_overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#22000000"
        android:clickable="true"
        android:elevation="19dp"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ProgressBar
        android:id="@+id/main_loading"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:elevation="20dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
