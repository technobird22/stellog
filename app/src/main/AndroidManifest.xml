<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:name=".StellogApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:usesCleartextTraffic="true"
        android:icon="@drawable/ic_stellog_launcher"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_stellog_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.Stellog">
        <activity
            android:name=".ui.AiAssistantActivity"
            android:exported="false" />
        <activity
            android:name=".ui.AiSettingsActivity"
            android:exported="false" />
        <activity
            android:name=".ui.HabitFilterActivity"
            android:exported="false" />
        <activity
            android:name=".ui.RecordDetailActivity"
            android:exported="false" />
        <activity
            android:name=".ui.CreateHabitActivity"
            android:exported="false" />
        <activity
            android:name=".ui.ReminderEditActivity"
            android:exported="false"
            android:theme="@style/Theme.Stellog.Dialog"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Stellog.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".receiver.ReminderBroadcastReceiver"
            android:exported="false" />
    </application>

</manifest>
